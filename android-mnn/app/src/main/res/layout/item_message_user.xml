<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="12dp">
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="48dp"
        android:background="@drawable/bg_chat_user"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp">
        <ImageView android:id="@+id/image" android:layout_width="210dp" android:layout_height="180dp"
            android:layout_marginBottom="8dp" android:clipToOutline="true"
            android:contentDescription="Attached image" android:scaleType="centerCrop" android:visibility="gone"/>
        <TextView android:id="@+id/message" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:maxWidth="300dp" android:textColor="#FFFFFF" android:textIsSelectable="true" android:textSize="16sp"/>
    </LinearLayout>
</FrameLayout>
